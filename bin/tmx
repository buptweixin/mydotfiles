#!/usr/bin/env bash

set -euo pipefail

sanitize_name() {
  printf '%s' "${1:-}" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's#[^a-z0-9._-]+#-#g; s#^-+##; s#-+$##; s#-+#-#g'
}

resolve_session_name() {
  local requested="${1:-}"
  local git_root=""

  if [[ "$requested" == "here" || "$requested" == "." ]]; then
    git_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$git_root" ]]; then
      sanitize_name "$(basename "$git_root")"
      return
    fi

    sanitize_name "$(basename "$PWD")"
    return
  fi

  if [[ -n "$requested" ]]; then
    sanitize_name "$requested"
    return
  fi

  sanitize_name "${TMUX_SESSION_NAME:-main}"
}

if [[ -n "${TMUX-}" ]]; then
  exec "${SHELL:-/bin/zsh}" -l
fi

session_name="$(resolve_session_name "${1:-}")"
session_name="${session_name:-main}"

exec tmux new-session -A -s "$session_name"
